{
  "ReverseProxy": {
    "Routes": {
      "function-api": {
        "ClusterId": "function-local",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "mock-api": {
        "ClusterId": "wiremock",
        "Match": {
          "Path": "/mock/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "function-local": {
        "Destinations": {
          "function-local-1": {
            "Address": "http://localhost:7071/"
          }
        }
      },
      "wiremock": {
        "Destinations": {
          "wiremock-1": {
            "Address": "http://localhost:8081/"
          }
        }
      }
    }
  }
}
